# Copy this file to terraform.tfvars and fill in your values

project_id  = "your-gcp-project-id"
region      = "us-central1"
zone        = "us-central1-a"
environment = "dev"

# GKE configuration
gke_node_machine_type = "n2-standard-4"
gke_min_nodes         = 1
gke_max_nodes         = 1
# gke_master_ipv4_cidr_block = "172.16.0.0/28"

# Database configuration
db_tier     = "db-custom-2-4096"
db_password = "your-secure-password-here"

# Networking (managed mode)
# network_mode      = "managed"
# vpc_cidr          = "10.0.0.0/16"
# gke_pods_cidr     = "10.1.0.0/16"
# gke_services_cidr = "10.2.0.0/16"

# Networking (existing mode example)
network_mode                               = "existing"
existing_network_name                      = "default"
existing_host_subnet_name                  = "default"
# Leave existing_gke_subnet_name empty to create a dedicated Capsule GKE subnet
# inside the reused VPC. Set the CIDRs below to ranges that do not overlap with
# existing subnet primary ranges, secondary ranges, or service networking ranges.
gke_subnet_cidr       = "10.96.0.0/20"
gke_pods_cidr         = "10.88.0.0/14"
gke_services_cidr     = "10.92.0.0/20"
gke_master_ipv4_cidr_block = "172.16.0.16/28"
# If you already have a dedicated GKE subnet with secondary ranges, uncomment:
# existing_gke_subnet_name                   = "capsule-test-gke"
# existing_gke_pods_secondary_range_name     = "pods"
# existing_gke_services_secondary_range_name = "services"
# manage_existing_network_nat controls whether this module owns NAT for the
# reused subnets. Leave it false if the shared VPC already provides egress.
# manage_existing_network_nat                = false
# manage_existing_network_private_service_connection should stay false unless
# this module should reserve and own service networking for Cloud SQL.
# manage_existing_network_private_service_connection = false
# private_service_range_name                 = "capsule-test-private-ip"
# private_service_range_address              = "10.10.0.0"
# private_service_range_prefix_length        = 16

# Container Registry (Artifact Registry)
container_registry_location  = "us-central1"
container_registry_repo_name = "capsule"
