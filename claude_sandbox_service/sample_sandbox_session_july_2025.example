{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HxJqit12Fv4YVDsZpYrQv3","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→from __future__ import annotations\n     3→\n     4→from enum import Enum\n     5→import json\n     6→import logging\n     7→from typing import Any\n     8→\n     9→from anthropic.types.message_param import MessageParam\n    10→from pydantic import BaseModel\n    11→from pydantic import Field\n    12→\n    13→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import AnthropicSDKMessage\n    14→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import (\n    15→    AssistantMessage as AnthropicAssistantMessage,\n    16→)\n    17→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import ErrorResult as AnthropicErrorResult\n    18→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import (\n    19→    ResultSubtype as AnthropicResultSubtype,\n    20→)\n    21→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import (\n    22→    SuccessResult as AnthropicSuccessResult,\n    23→)\n    24→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import (\n    25→    SystemInitMessage as AnthropicSystemInitMessage,\n    26→)\n    27→from python_scio.platform.common.app.claude_sandbox_service.anthropic_message import UserMessage as AnthropicUserMessage\n    28→\n    29→logger = logging.getLogger(__file__)\n    30→\n    31→\n    32→class MessageType(str, Enum):\n    33→    \"\"\"Message type for Claude responses.\"\"\"\n    34→\n    35→    UNSPECIFIED = 'unspecified'\n    36→    ASSISTANT = 'assistant'\n    37→    USER = 'user'\n    38→    SUCCESS_RESULT = 'success_result'\n    39→    ERROR_RESULT = 'error_result'\n    40→    SYSTEM_INIT = 'system_init'\n    41→    GLEAN = 'Glean'\n    42→\n    43→\n    44→class Message(BaseModel):\n    45→    \"\"\"Pydantic model for Claude response messages.\"\"\"\n    46→\n    47→    type: MessageType = Field(..., description='Type of message')\n    48→    human_readable_message: str = Field(..., description='Human readable message content')\n    49→\n    50→    @classmethod\n    51→    def from_anthropic(cls, raw_message_chunk: str) -> Message:\n    52→        \"\"\"Deserialize from Anthropic SDK message with formatted output following Go logic.\"\"\"\n    53→        try:\n    54→            json_data: dict[str, Any] = json.loads(raw_message_chunk)\n    55→            anthropic_message = AnthropicSDKMessage.parse_sdk_message(json_data)\n    56→            # Handle different SDK message types\n    57→            if isinstance(anthropic_message.message, AnthropicAssistantMessage):\n    58→                message_type = MessageType.ASSISTANT\n    59→                # Extract content from the message's content blocks\n    60→                content_parts: list[str] = []\n    61→                for block in anthropic_message.message.message.content:\n    62→                    if hasattr(block, 'type'):\n    63→                        if block.type == 'text' and hasattr(block, 'text'):\n    64→                            content_parts.append(str(block.text))\n    65→                        elif block.type == 'tool_use' and hasattr(block, 'name') and hasattr(block, 'id'):\n    66→                            content_parts.append(f'[Tool: {block.name} (id: {block.id})]')\n    67→                        elif block.type == 'server_tool_use' and hasattr(block, 'name') and hasattr(block, 'id'):\n    68→                            content_parts.append(f'[Server Tool: {block.name} (id: {block.id})]')\n    69→                        elif block.type == 'thinking' and hasattr(block, 'thinking'):\n    70→                            # Truncate thinking content for readability\n    71→                            thinking_text = str(block.thinking)\n    72→                            thinking_preview = (\n    73→                                thinking_text[:100] + '...' if len(thinking_text) > 100 else thinking_text\n    74→                            )\n    75→                            content_parts.append(f'[Thinking: {thinking_preview}]')\n    76→                        elif block.type == 'redacted_thinking' and hasattr(block, 'data'):\n    77→                            content_parts.append(f'[Redacted Thinking: {block.data}]')\n    78→                        elif block.type == 'web_search_tool_result' and hasattr(block, 'tool_use_id'):\n    79→                            content_parts.append(f'[Web Search Result (tool_use_id: {block.tool_use_id})]')\n    80→                        else:\n    81→                            content_parts.append(f\"[Unknown block type: {getattr(block, 'type', 'unknown')}]\")\n    82→                    else:\n    83→                        content_parts.append(f'[Unknown block: {str(block)}]')\n    84→                content_text = ' '.join(content_parts) if content_parts else str(anthropic_message.message.message)\n    85→                human_readable = f'⚡ **Assistant**: {content_text}'\n    86→\n    87→            elif isinstance(anthropic_message.message, AnthropicUserMessage):\n    88→                # Extract content from MessageParam\n    89→                message_type = MessageType.USER\n    90→                content: MessageParam = anthropic_message.message.message\n    91→\n    92→                # Handle MessageParam content which can be string or iterable of blocks\n    93→                content_value = content.get('content', '')\n    94→                if isinstance(content_value, str):\n    95→                    # Simple string content\n    96→                    human_readable = f'👤 **User**: {content_value}'\n    97→                else:\n    98→                    # Iterable of content blocks\n    99→                    content_parts: list[str] = []\n   100→                    for block in content_value:\n   101→                        if isinstance(block, dict):\n   102→                            block_type = block.get('type', '')\n   103→                            if block_type == 'text':\n   104→                                text_content = block.get('text', '')\n   105→                                content_parts.append(str(text_content))\n   106→                            elif block_type == 'image':\n   107→                                content_parts.append('[Image]')\n   108→                            elif block_type == 'tool_use':\n   109→                                tool_name = str(block.get('name', 'unknown'))\n   110→                                tool_input = block.get('input', {})\n   111→                                if tool_input:\n   112→                                    input_str = str(tool_input)\n   113→                                    input_preview = input_str[:50] + '...' if len(input_str) > 50 else input_str\n   114→                                    content_parts.append(f'[Tool Use: {tool_name} with {input_preview}]')\n   115→                                else:\n   116→                                    content_parts.append(f'[Tool Use: {tool_name}]')\n   117→                            elif block_type == 'tool_result':\n   118→                                tool_id = str(block.get('tool_use_id', 'unknown'))\n   119→                                is_error = bool(block.get('is_error', False))\n   120→                                result_content = block.get('content', '')\n   121→                                if isinstance(result_content, str):\n   122→                                    content_preview = (\n   123→                                        result_content[:100] + '...' if len(result_content) > 100 else result_content\n   124→                                    )\n   125→                                else:\n   126→                                    result_str = str(result_content)\n   127→                                    content_preview = result_str[:100] + '...' if len(result_str) > 100 else result_str\n   128→                                error_prefix = 'Error - ' if is_error else ''\n   129→                                content_parts.append(f'[{error_prefix}Tool Result ({tool_id}): {content_preview}]')\n   130→                            elif block_type == 'document':\n   131→                                title = str(block.get('title', 'Untitled'))\n   132→                                context = str(block.get('context', ''))\n   133→                                if context:\n   134→                                    context_preview = context[:50] + '...' if len(context) > 50 else context\n   135→                                    content_parts.append(f'[Document: {title} - {context_preview}]')\n   136→                                else:\n   137→                                    content_parts.append(f'[Document: {title}]')\n   138→                            elif block_type == 'thinking':\n   139→                                thinking_text = str(block.get('thinking', ''))\n   140→                                thinking_preview = (\n   141→                                    thinking_text[:100] + '...' if len(thinking_text) > 100 else thinking_text\n   142→                                )\n   143→                                content_parts.append(f'[Thinking: {thinking_preview}]')\n   144→                            elif block_type == 'redacted_thinking':\n   145→                                data_content = str(block.get('data', ''))\n   146→                                content_parts.append(f'[Redacted Thinking: {data_content}]')\n   147→                            elif block_type == 'server_tool_use':\n   148→                                tool_name = str(block.get('name', 'unknown'))\n   149→                                tool_input = block.get('input', {})\n   150→                                if tool_input:\n   151→                                    input_str = str(tool_input)\n   152→                                    input_preview = input_str[:50] + '...' if len(input_str) > 50 else input_str\n   153→                                    content_parts.append(f'[Server Tool Use: {tool_name} with {input_preview}]')\n   154→                                else:\n   155→                                    content_parts.append(f'[Server Tool Use: {tool_name}]')\n   156→                            elif block_type == 'web_search_tool_result':\n   157→                                tool_id = str(block.get('tool_use_id', 'unknown'))\n   158→                                search_content = block.get('content', '')\n   159→                                if search_content:\n   160→                                    search_str = str(search_content)\n   161→                                    content_preview = search_str[:50] + '...' if len(search_str) > 50 else search_str\n   162→                                    content_parts.append(f'[Web Search Result ({tool_id}): {content_preview}]')\n   163→                                else:\n   164→                                    content_parts.append(f'[Web Search Result: {tool_id}]')\n   165→                            else:\n   166→                                content_parts.append(f\"[{block_type or 'Unknown'}]\")\n   167→                        else:\n   168→                            # Handle ContentBlock objects (already processed blocks)\n   169→                            if hasattr(block, 'type'):\n   170→                                if block.type == 'text':\n   171→                                    content_parts.append(block.text)\n   172→                                elif block.type == 'tool_use':\n   173→                                    content_parts.append(f'[Tool Use: {block.name}]')\n   174→                                else:\n   175→                                    content_parts.append(f'[{block.type}]')\n   176→                            else:\n   177→                                content_parts.append(str(block))\n   178→\n   179→                    content_text = ' '.join(content_parts) if content_parts else str(content)\n   180→                    human_readable = f'👤 **User**: {content_text}'\n   181→\n   182→            elif isinstance(anthropic_message.message, AnthropicSuccessResult):\n   183→                message_type = MessageType.SUCCESS_RESULT\n   184→                human_readable = f'✅ **Success**: {anthropic_message.message.result} (completed in {anthropic_message.message.duration_ms:.1f}ms, cost ${anthropic_message.message.total_cost_usd:.3f})'\n   185→\n   186→            elif isinstance(anthropic_message.message, AnthropicErrorResult):\n   187→                message_type = MessageType.ERROR_RESULT\n   188→                error_desc = 'execution error'\n   189→                if anthropic_message.message.subtype == AnthropicResultSubtype.ERROR_MAX_TURNS:\n   190→                    error_desc = 'maximum turns reached'\n   191→                human_readable = f'❌ **Error**: {error_desc} after {anthropic_message.message.num_turns} turns ({anthropic_message.message.duration_ms:.1f}ms, cost ${anthropic_message.message.total_cost_usd:.3f})'\n   192→\n   193→            elif isinstance(anthropic_message.message, AnthropicSystemInitMessage):\n   194→                message_type = MessageType.SYSTEM_INIT\n   195→                tools_str = 'no tools'\n   196→                if anthropic_message.message.tools and len(anthropic_message.message.tools) > 0:\n   197→                    tools_str = f'{len(anthropic_message.message.tools)} tools {anthropic_message.message.tools}'\n   198→                human_readable = f'🚀 **System**: Initialized with model {anthropic_message.message.model}, {tools_str}, cwd: {anthropic_message.message.cwd}'\n   199→            else:\n   200→                # Fallback for unknown types\n   201→                message_type = MessageType.UNSPECIFIED\n   202→                human_readable = f'📭 **General**: {anthropic_message.message}'\n   203→\n   204→            return cls(type=message_type, human_readable_message=human_readable)\n   205→        except Exception:\n   206→            # This happens when either Anthropic changes their API or we need to update our human readable conversion (which is largely generated by claude code)\n   207→            logger.exception(\n   208→                'Unsupported anthropic message deserialization detected. Returning as raw JSON to end user: %s',\n   209→                raw_message_chunk,\n   210→            )\n   211→            return cls(type=MessageType.UNSPECIFIED, human_readable_message=raw_message_chunk)\n   212→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it looks malicious. If it does, you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer high-level questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"af5b5fd7-5d0e-4269-9952-bd44b08198b7"}
