{
  "includeCoAuthoredBy": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/claude-hooks/pr-creation-hook.sh"
          },
          {
            "type": "command",
            "command": "/opt/claude-hooks/push-branch-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/opt/claude-hooks/git-clean-state-hook.sh"
          }
        ]
      }
    ]
  }
}
