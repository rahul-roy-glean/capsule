# Minimal dev rootfs for local Firecracker testing (~150-200MB).
# Contains only systemd + capsule-thaw-agent + basic utils.
# No Go, Java, Node, Python, Bazel, GitHub runner, SSH, or git.

# --- Stage 1: build capsule-thaw-agent ---
FROM golang:1.24 AS builder

WORKDIR /build
COPY go.mod go.sum ./
COPY cmd/capsule-thaw-agent/ ./cmd/capsule-thaw-agent/
COPY pkg/ ./pkg/

RUN CGO_ENABLED=0 GOOS=linux go build -o /capsule-thaw-agent ./cmd/capsule-thaw-agent

# --- Stage 2: minimal rootfs ---
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    systemd \
    systemd-sysv \
    dbus \
    iproute2 \
    iputils-ping \
    curl \
    jq \
    procps \
    sudo \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create runner user with NOPASSWD sudo
RUN useradd -m -s /bin/bash -G sudo runner \
    && echo "runner ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/runner

# Create workspace directory
RUN mkdir -p /workspace /var/run/capsule-thaw-agent /var/log/capsule-thaw-agent \
    && chown -R runner:runner /workspace

# Configure systemd
RUN systemctl set-default multi-user.target \
    && systemctl mask \
        systemd-resolved.service \
        systemd-networkd-wait-online.service \
        systemd-timesyncd.service \
        systemd-journald-audit.socket \
        sys-kernel-debug.mount \
        sys-kernel-tracing.mount

# Configure network (static IP set by capsule-thaw-agent via MMDS)
COPY images/microvm/rootfs/etc/systemd/network/10-eth0.network /etc/systemd/network/
RUN systemctl enable systemd-networkd

# Install capsule-thaw-agent binary
COPY --from=builder /capsule-thaw-agent /usr/local/bin/capsule-thaw-agent

# Thaw-agent systemd service — use runner user, skip features not needed for dev
RUN printf '[Unit]\n\
Description=Thaw Agent\n\
After=network.target\n\
Wants=network.target\n\
\n\
[Service]\n\
Type=simple\n\
ExecStart=/usr/local/bin/capsule-thaw-agent\n\
Restart=on-failure\n\
RestartSec=2\n\
StandardOutput=journal\n\
StandardError=journal\n\
Environment=LOG_LEVEL=debug\n\
Environment=HOME=/root\n\
\n\
[Install]\n\
WantedBy=multi-user.target\n' > /etc/systemd/system/capsule-thaw-agent.service \
    && systemctl enable capsule-thaw-agent.service

# Serial console
RUN echo "ttyS0" >> /etc/securetty \
    && systemctl enable serial-getty@ttyS0.service

# Hostname
RUN echo "dev-runner" > /etc/hostname

# DNS
RUN echo "nameserver 8.8.8.8" > /etc/resolv.conf.default

# Init symlink for Firecracker boot
RUN ln -sf /lib/systemd/systemd /init

# Cleanup
RUN apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*
